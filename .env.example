# Admin panel credentials
ADMIN_EMAIL=admin@lumiereprestige.com
ADMIN_PASSWORD=Admin123!ChangeMe

# JWT secret (generate a random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact form
CONTACT_EMAIL=contacto@lumiereprestige.com

# WhatsApp (international format without +)
NEXT_PUBLIC_WHATSAPP_NUMBER=5215512345678
NEXT_PUBLIC_PHONE_NUMBER=+525512345678

# Chat / Live support (Tawk.to, Crisp, Intercom)
NEXT_PUBLIC_CHAT_PROVIDER=prepared
NEXT_PUBLIC_CHAT_WIDGET_ID=

# AI Assistant (OpenAI)
OPENAI_API_KEY=
NEXT_PUBLIC_AI_ASSISTANT_ENABLED=false

# Payment providers
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
SQUARE_APP_ID=
SQUARE_ACCESS_TOKEN=
NEXT_PUBLIC_PAYMENTS_ENABLED=false
NEXT_PUBLIC_DEFAULT_PAYMENT_PROVIDER=stripe

# Analytics & tracking
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_FB_PIXEL_ID=

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# R2 public URL (custom domain or r2.dev public bucket URL)
# Leave empty to serve uploads via /api/media/... in local dev
NEXT_PUBLIC_R2_PUBLIC_URL=

# Cloudflare KV/R2 bindings are configured in wrangler.jsonc (CMS_KV, CMS_R2)
